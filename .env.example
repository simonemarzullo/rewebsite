# Required. FollowUpBoss personal API key (Admin -> API in FollowUpBoss).
FUB_API_KEY=

# Optional. The lead source name shown in FollowUpBoss for these leads.
FUB_SOURCE=Simone Marzullo Website

# Optional. Only set FUB_SYSTEM_KEY if you complete FollowUpBoss "system
# registration" (see README). If either of these two is missing, requests
# are sent without them -- Basic Auth with FUB_API_KEY is what actually
# authenticates the request.
FUB_SYSTEM=Simone Marzullo Website
FUB_SYSTEM_KEY=

# Email notifications: every lead (including someone who abandons a form
# partway through, subject-tagged "Dropped out") is emailed here in addition
# to being pushed to FollowUpBoss. Required for that feature to work -- if
# SMTP_HOST is unset, email notifications are silently skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_TO=Simone@SimoneMarzullo.com
