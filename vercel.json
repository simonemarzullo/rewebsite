{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/seller", "destination": "/api/seller-page" },
    { "source": "/buyer", "destination": "/api/buyer-page" },
    { "source": "/homevaluation", "destination": "/api/home-valuation-page" },
    { "source": "/investor", "destination": "/api/investor-page" },
    { "source": "/cashoffer", "destination": "/api/cash-offer-page" },
    { "source": "/flipcalculator", "destination": "/flip-calculator.html" }
  ]
}
