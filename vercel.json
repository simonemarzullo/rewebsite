{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/seller", "destination": "/sell", "permanent": true },
    { "source": "/buyer", "destination": "/buy", "permanent": true },
    { "source": "/investor", "destination": "/invest", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sell", "destination": "/api/sell-page" },
    { "source": "/buy", "destination": "/api/buy-page" },
    { "source": "/homevaluation", "destination": "/api/home-valuation-page" },
    { "source": "/invest", "destination": "/api/invest-page" },
    { "source": "/cashoffer", "destination": "/api/cash-offer-page" },
    { "source": "/flipcalculator", "destination": "/flip-calculator.html" },
    { "source": "/home", "destination": "/index.html" },
    { "source": "/search", "destination": "/search.html" },
    { "source": "/about", "destination": "/api/about-page" },
    { "source": "/contact", "destination": "/api/contact-page" }
  ]
}
