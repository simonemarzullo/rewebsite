{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/seller", "destination": "/sell", "permanent": true },
    { "source": "/buyer", "destination": "/buy", "permanent": true },
    { "source": "/investor", "destination": "/invest", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sell", "destination": "/api/sell-page" },
    { "source": "/buy", "destination": "/api/buy-page" },
    { "source": "/homevaluation", "destination": "/api/home-valuation-page" },
    { "source": "/invest", "destination": "/api/invest-page" },
    { "source": "/cashoffer", "destination": "/api/cash-offer-page" },
    { "source": "/flipcalculator", "destination": "/flip-calculator.html" },
    { "source": "/home", "destination": "/index.html" },
    { "source": "/about", "destination": "/api/about-page" },
    { "source": "/contact", "destination": "/api/contact-page" },
    { "source": "/areas", "destination": "/api/areas" },
    { "source": "/areas/santa-monica", "destination": "/api/area-santa-monica" },
    { "source": "/areas/venice", "destination": "/api/area-venice" },
    { "source": "/areas/beverly-hills", "destination": "/api/area-beverly-hills" },
    { "source": "/areas/bel-air", "destination": "/api/area-bel-air" },
    { "source": "/areas/malibu", "destination": "/api/area-malibu" },
    { "source": "/areas/culver-city", "destination": "/api/area-culver-city" },
    { "source": "/areas/century-city", "destination": "/api/area-century-city" },
    { "source": "/areas/mar-vista", "destination": "/api/area-mar-vista" },
    { "source": "/areas/hollywood", "destination": "/api/area-hollywood" }
  ]
}
